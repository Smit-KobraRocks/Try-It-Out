{
  "manifest_version": 3,
  "name": "AI Virtual Try-On",
  "version": "1.0",
  "description": "Try on clothes virtually from supported e-commerce sites.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.myntra.com/*",
    "https://*.flipkart.com/*",
    "https://*.zara.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.myntra.com/*",
        "https://*.flipkart.com/*",
        "https://*.zara.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Virtual Try-On"
  }
}
